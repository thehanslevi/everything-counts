<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Push Notifications. Xcode substitutes "production" automatically when
	     archiving for TestFlight/App Store; local device debug builds use this
	     "development" value (sandbox APNs). -->
	<key>aps-environment</key>
	<string>development</string>
</dict>
</plist>
